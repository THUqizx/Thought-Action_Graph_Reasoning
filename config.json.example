{
  "sparql_endpoint": "http://your-sparql-endpoint.com/sparql/",
  
  "paths": {
    "llama3_1_model_path": "/path/to/Llama-3.1-8B-Instruct",
    "tag_path": "/path/to/TAGv2(WebQSP+CWQ,Freebase).pkl",
    "qwen3_embedding_model_path": "/path/to/Qwen3-Embedding-4B/",
    "query_embeddings_path": "/path/to/WebQSP_CWQ_Question_Embeddings.pkl",
    "answer_type_name_embeddings_path": "/path/to/AnswerTypeName_WebQSP_CWQ_Embeddingsv2.pkl",
    "fasttext_embeddings_path": "/path/to/FastText/dbpedia.bin",
    "webqsp_test_path": "/path/to/WebQSP/WebQSP.test.json",
    "cwq_test_path": "/path/to/CWQ/CWQ.test.json",
    "grailqa_test_path": "/path/to/GrailQA/GrailQA.test.json",
    "predict_type_name_prompt_path": "/path/to/prompt/predict_typeName_prompt.txt",
    "generate_meta_action_chain_prompt_path": "/path/to/prompt/generate_meta_action_chain_prompt.txt",
    "reasoning_prompt_path": "/path/to/prompt/reasoning_prompt.txt",
    "answer_save_path": "/path/to/save/results"
  },
  
  "sparql": {
    "endpoint": "http://your-sparql-endpoint.com/sparql/"
  },
  
  "parameters": {
    "tag_explore_breadth": 5,
    "tag_explore_depth": 3,
    "max_attempts": 5,
    "delay": 30,
    "batch_size": 10,
    "number_of_triples": 200,
    "cuda_visible_devices": "0,1"
  },
  
  "model_settings": {
    "llama3_1_dtype": "bfloat16",
    "max_new_tokens": 32768,
    "temperature": 0.7,
    "top_p": 0.9
  },
  
  "gpt_settings": {
    "max_attempts": 5,
    "delay": 30,
    "temperature": 0.7,
    "max_tokens": null
  },
  
  "openai": {
    "api_key": "your-api-key-here",
    "base_url": "https://api.chatanywhere.tech/v1",
    "default_model": "gpt-4o",
    "max_attempts": 5,
    "delay_seconds": 30
  },
  
  "retrieval": {
    "top_k": 5,
    "max_depth": 10,
    "similarity_threshold": 0.7
  },
  
  "data": {
    "input_dataset": "/path/to/input_dataset.json",
    "output_directory": "/path/to/output/results"
  },
  
  "tag_config": {
    "explore_breadth": 5,
    "explore_depth": 3,
    "number_of_triples": 100
  }
}
